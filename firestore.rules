// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Document ID: userId (Firebase Auth UID)
// Fields:
//   - email: string (required)
//   - role: string (required, 'admin' or 'bod')
//   - gradeLevel: string (optional, 'Grade 7', 'Grade 8', 'Grade 9', 'Grade 10', 'All')
//   - name: string (optional)
//
// Collection: teachers
// Document ID: auto-generated
// Fields:
//   - name: string (required)
//   - email: string (required)
//   - gender: string (optional, 'Male' or 'Female')
//   - contactNumber: string (optional)
//   - gradeLevel: string (required, 'Grade 7', 'Grade 8', 'Grade 9', 'Grade 10')
//   - paidDueIds: list (required, array of strings)
//   - lastReceiptSent: timestamp (optional)
//   - remitted: bool (optional)
//   - remittanceId: string (optional)
//   - paymentHistory: list (optional, array of objects containing dueId, amount, date, collector)
//
// Collection: dues
// Document ID: auto-generated
// Fields:
//   - name: string (required)
//   - amount: number (required)
//
// Collection: remittances
// Document ID: auto-generated
// Fields:
//   - bodId: string (required)
//   - bodName: string (required)
//   - gradeLevel: string (required)
//   - amount: number (required)
//   - timestamp: timestamp (required)
//   - status: string (required, 'pending' or 'verified')
//   - teacherIds: list (required, array of strings)
//
// Collection: expenses
// Document ID: auto-generated
// Fields:
//   - description: string (required)
//   - amount: number (required)
//   - category: string (optional)
//   - timestamp: timestamp (required)
//   - adminId: string (required)
//
// Collection: audit_logs
// Document ID: auto-generated
// Fields:
//   - action: string (required)
//   - details: string (optional)
//   - userId: string (required)
//   - userName: string (optional)
//   - timestamp: timestamp (required)
//   - type: string (required, 'info', 'warning', 'critical')
//
// Collection: initial_balances
// Document ID: auto-generated
// Fields:
//   - amount: number (required)
//   - description: string (optional)
//   - timestamp: timestamp (required)
//   - adminId: string (required)
//   - adminName: string (optional)
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserData() {
      let path = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(path) ? get(path).data : null;
    }

    function isAdmin() {
      let data = getUserData();
      let isPrimaryAdmin = request.auth.token.email == "lpcaanhsfacultyclubofficers@gmail.com";
      return isAuthenticated() && (isPrimaryAdmin || (data != null && data.role == 'admin'));
    }

    function isBOD() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'bod';
    }

    function isTeacher(email) {
      let data = getUserData();
      return isAuthenticated() && (
        (request.auth.token.email != null && request.auth.token.email.lower() == email.lower()) || 
        (data != null && data.role == 'teacher' && data.email.lower() == email.lower())
      );
    }

    function isValidDue(data) {
      return data.keys().hasAll(['name', 'amount']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.amount is number && data.amount >= 0;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['title', 'message', 'type', 'isRead', 'timestamp', 'targetId']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.message is string && data.message.size() > 0 && data.message.size() < 2000 &&
             data.type in ['welcome', 'announcement', 'payment', 'system'] &&
             data.isRead is bool &&
             data.targetId is string;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow create: if isAuthenticated() && (
        request.auth.uid == userId || 
        isAdmin() || 
        (request.resource.data.role == 'teacher' && (request.auth.token.email == request.resource.data.email || (getUserData() != null && getUserData().email == request.resource.data.email)))
      );
      allow update: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isBOD();
      allow update: if isAdmin() || isBOD() || (isTeacher(resource.data.email) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['welcomeNotificationSent', 'termsAgreed', 'termsAgreedDate', 'name', 'email', 'lastName', 'firstName', 'middleInitial', 'contactNumber']));
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read: if isAuthenticated() && (isAdmin() || isTeacher(get(/databases/$(database)/documents/teachers/$(teacherId)).data.email));
        allow create: if (isAdmin() || isBOD() || isTeacher(get(/databases/$(database)/documents/teachers/$(teacherId)).data.email)) && isValidNotification(request.resource.data);
        allow update: if isAuthenticated() && (isAdmin() || (isTeacher(get(/databases/$(database)/documents/teachers/$(teacherId)).data.email) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead', 'replies'])));
        allow delete: if isAdmin() || isTeacher(get(/databases/$(database)/documents/teachers/$(teacherId)).data.email);
      }
    }

    match /dues/{dueId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isBOD();
      allow update: if isAdmin() || isBOD();
      allow delete: if isAdmin();
    }

    match /remittances/{remittanceId} {
      allow read: if isAuthenticated();
      allow create: if isBOD();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /expenses/{expenseId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /initial_balances/{balanceId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if false;
      allow delete: if isAdmin();
    }

    match /settings/global {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
  }
}
