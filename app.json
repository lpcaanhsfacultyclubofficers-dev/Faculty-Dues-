{
  "expo": {
    "name": "Faculty Club Mobile",
    "slug": "faculty-club-mobile",
    "scheme": "faculty-club-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.facultyclub.mobile"
    },
    "android": {
      "package": "com.facultyclub.mobile",
      "versionCode": 1,
      "permissions": ["CAMERA"]
    },
    "plugins": [
      [
        "expo-build-properties",
        {
          "android": {
            "kotlinVersion": "1.8.10",
            "extraMavenRepos": [
              "https://www.jitpack.io"
            ]
          }
        }
      ],
      "expo-document-picker"
    ]
  }
}
